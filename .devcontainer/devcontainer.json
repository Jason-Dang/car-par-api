{
    "name": "Car Park API",
    "dockerComposeFile": [
        "../docker-compose.yml",
        "docker-compose.yml"
    ],
    "service": "app",
    "workspaceFolder": "/workspace",
    "remoteUser": "vscode",
    "forwardPorts": [8080, 7080],
    "portsAttributes": {
        "8080": { "label": "Spring Boot API" },
        "7080": { "label": "Keycloak" }
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "vscjava.vscode-java-pack",
                "vmware.vscode-spring-boot",
                "vscjava.vscode-spring-initializr",
                "redhat.vscode-yaml",
                "ms-azuretools.vscode-docker"
            ],
            "settings": {
                "java.jdt.ls.java.home": "/opt/java/openjdk",
                "spring-boot.ls.java.home": "/opt/java/openjdk",
                "editor.formatOnSave": true,
                "files.eol": "\n"
            }
        }
    },
    "postCreateCommand": "chmod +x mvnw && ./mvnw dependency:resolve -q"
}