# Keycloak-Postgres configuration
# KC_DB_ROOT_PASSWORD is the Postgres superuser password.
# The KC_DB_USER / KC_DB_DATABASE are created by postgres/init.sh on first boot.
KC_DB_ROOT_PASSWORD=
KC_DB_DATABASE=local_db
KC_DB_USER=local_user
KC_DB_PASSWORD=

# Keycloak admin credentials
KC_USER=local_admin
KC_PASSWORD=

# H2 console credentials
H2_USER=local_admin
H2_PASSWORD=

# Keycloak test user credentials (injected into realm import via ${env.*} substitution)
KC_TEST_USER_PASSWORD=
KC_TEST_ADMIN_PASSWORD=